{
  "name": "events-timer",
  "version": "3.1.0",
  "description": "A simple countdown application for speakers at events, conferences, etc.",
  "author": "Martin Hlaváč <hlavacm@hotmail.com>",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "test": "npm run typecheck && npm run test:unit && npm run test:e2e",
    "test:ci": "npm run typecheck && npm run test:coverage && npm run test:e2e",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "screenshot": "npm run build && node scripts/capture-screenshot.mjs"
  },
  "dependencies": {
    "lucide-vue-next": "^0.525.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@tailwindcss/vite": "^4.1.11",
    "@types/node": "^24.0.10",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.30.1",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.0",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.10"
  },
  "engines": {
    "node": ">=24"
  }
}
